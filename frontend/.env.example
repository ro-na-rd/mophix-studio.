# Frontend API endpoint (use relative path for same-origin deployment, or full URL for external backend)
REACT_APP_API_URL=/api/v1
REACT_APP_SITE_NAME=Mophix Studio

# For production backend, set REACT_APP_API_URL to the backend deployment URL
# Example: REACT_APP_API_URL=https://mophix-api.railway.app/api/v1
